# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application ID
DISCORD_APP_ID=your_application_id_here

# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://poker_user:poker_password@localhost:5432/poker_bot

# For synchronous operations (alembic migrations, etc.)
DATABASE_URL_SYNC=postgresql+psycopg2://poker_user:poker_password@localhost:5432/poker_bot

# Server Settings
GUILD_ID=your_guild_id_here

# Poker Configuration
DEFAULT_STARTING_CHIPS=10000
REBUY_CHIPS=5000
REBUY_COOLDOWN_DAYS=7
MIN_ACCOUNT_AGE_DAYS=30
